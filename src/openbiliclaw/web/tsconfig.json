{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "noEmit": true,
    "sourceMap": true,
    "skipLibCheck": true
  },
  "include": ["js/**/*.ts", "shared/**/*.ts", "desktop/assets/js/**/*.ts", "types/**/*.d.ts"]
}
