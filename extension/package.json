{
  "name": "openbiliclaw-extension",
  "version": "0.3.168",
  "private": true,
  "type": "module",
  "scripts": {
    "api:generate": "node ../openapi/generate-client.mjs --write",
    "api:check": "node ../openapi/generate-client.mjs --check",
    "build": "npm run clean && npm run build:types && npm run build:bundle",
    "build:bundle": "node scripts/build.mjs",
    "build:types": "tsc -p tsconfig.json --emitDeclarationOnly",
    "build:firefox": "TARGET=firefox npm run clean && npm run build:types && TARGET=firefox npm run build:bundle",
    "clean": "rm -rf dist dist-firefox",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test --experimental-strip-types tests/*.test.ts",
    "package": "node scripts/package.mjs",
    "package:only": "node scripts/package.mjs --no-build",
    "package:firefox": "node scripts/package-firefox.mjs",
    "package:firefox:only": "node scripts/package-firefox.mjs --no-build",
    "sign:firefox": "node scripts/sign-firefox.mjs",
    "sign:firefox:only": "node scripts/sign-firefox.mjs --no-build",
    "webstore:upload": "node scripts/chrome-webstore-upload.mjs",
    "webstore:metadata": "node scripts/chrome-webstore-metadata.mjs"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.29",
    "esbuild": "^0.25.10",
    "typescript": "^5.9.2",
    "web-ext": "^10.5.0"
  },
  "overrides": {
    "adm-zip": "0.6.0",
    "brace-expansion": "1.1.16",
    "js-yaml": "4.3.0",
    "shell-quote": "1.10.0"
  }
}
